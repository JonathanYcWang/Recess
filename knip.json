{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["index.html", "src/background.ts", "src/content.ts"],
  "ignoreIssues": {
    "src/modules/**": ["exports", "types"],
    "src/adapters/browser/**": ["exports", "types"],
    "src/runtime/**": ["exports", "types"],
    "src/store/selectors/settingsProjectionSelectors.ts": ["exports"],
    "src/store/settingsClient.ts": ["exports"],
    "src/store/settingsConnectionAwareClient.ts": ["exports"],
    "src/store/settingsConnectionManager.ts": ["exports"],
    "src/store/blockListClient.ts": ["exports"],
    "src/store/blockListConnectionManager.ts": ["exports"],
    "src/store/blockListProjectionSubscription.ts": ["exports"],
    "src/store/accessContextSubscription.ts": ["exports"],
    "src/store/reducers/blockListProjectionReducer.ts": ["types"],
    "src/store/selectors/blockListProjectionSelectors.ts": ["exports"],
    "src/store/selectors/workstyleProfileProjectionSelectors.ts": ["exports"],
    "src/store/reducers/settingsProjectionReducer.ts": ["types"],
    "src/store/reducers/workstyleProfileProjectionReducer.ts": ["types"]
  },
  "project": ["src/**/*.{ts,tsx}", "!src/**/*.test.{ts,tsx}"],
  "ignoreFiles": [
    "src/components/PrizeWheel/**",
    "src/components/ParticleBurst/**",
    "src/components/QuizQuestion/**",
    "src/hooks/useParticles.ts",
    "src/hooks/useSettings.ts",
    "src/pages/QuizPage/**"
  ],
  "vite": {
    "config": ["vite.config.ts", "vite.background.config.ts"]
  }
}
